{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@shared/*": ["./ri/src/shared/*"]
    }
  },
  "include": ["ri/src/server/**/*", "ri/src/shared/**/*"],
  "exclude": ["node_modules", "client", "dist"]
}
