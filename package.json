{
  "name": "scoot",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite --config ri/src/client/vite.config.ts --port 5173\" \"tsx watch ri/src/server/index.ts\"",
    "build": "vite build --config ri/src/client/vite.config.ts && esbuild ri/src/server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc -p tsconfig.json && tsc -p ri/src/client/tsconfig.json",
    "db:push": "drizzle-kit push",
    "bot:create": "tsx ri/src/server/scripts/bot-create.ts",
    "bot:edit": "tsx ri/src/server/scripts/bot-edit.ts",
    "bot:invite": "tsx ri/src/server/scripts/bot-invite.ts",
    "seed:fakes": "tsx ri/src/server/scripts/seed-fake-users.ts",
    "seed:scoot34": "tsx ri/src/server/scripts/seed-scoot34.ts",
    "research:moses": "tsx ri/src/server/scripts/research-moses.ts",
    "session:save": "node scripts/save-session.cjs",
    "setup:memory": "bash scripts/setup-claude-memory.sh",
    "test": "node --import tsx --test 'ri/src/server/**/*.test.ts'",
    "docker:up": "docker compose -f ri/physical/docker-compose.yml up -d",
    "docker:up:build": "docker compose -f ri/physical/docker-compose.yml up -d --build",
    "docker:down": "docker compose -f ri/physical/docker-compose.yml down",
    "docker:logs": "docker compose -f ri/physical/docker-compose.yml logs -f",
    "docker:exec": "docker compose -f ri/physical/docker-compose.yml exec app"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@tanstack/react-query": "^5.74.4",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.42.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "hls.js": "^1.5.20",
    "lucide-react": "^0.487.0",
    "multer": "^2.1.1",
    "openai": "^4.97.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.14.1",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^6.0.2",
    "uuid": "^11.1.0",
    "wouter": "^3.5.3",
    "ws": "^8.18.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/node": "^22.15.3",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.11.13",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.25.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
