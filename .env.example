# Database
DATABASE_URL=postgresql://scoot:password@localhost:5432/scoot

# Session
SESSION_SECRET=replace_with_64_random_chars

# Default user — seeded automatically on first server start if the users table is empty.
# Required to log in on a fresh machine (public registration is disabled).
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=replace_me
DEFAULT_EMAIL=admin@example.com

# C core socket
SCOOTD_SOCKET=/tmp/scootd.sock

# LLM provider: "anthropic" | "openai_compat"
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514
# For vLLM or other OpenAI-compatible backend:
# LLM_PROVIDER=openai_compat
# LLM_API_URL=http://your-host:8000/v1
# LLM_MODEL=meta-llama/Llama-4-...

# Chat-bot mentions (the @<botname> in-room bot — separate from /bot page)
# Personality and per-bot config live in the `bots` table, not env.
BOT_ENABLED=true
BOT_HISTORY_WINDOW=20
BOT_MAX_REPLY_TOKENS=500
# Perplexity API key — enables real-time web search for bots with search_enabled=true
PERPLEXITY_API_KEY=
LOG_LEVEL=debug

# Data volume root — all persistent data (postgres, media, scootchain) lives here.
# Point this at your data volume mount point in production (e.g. /mnt/data/scoot).
# Defaults to /var/lib/scoot if unset.
DATA_DIR=/var/lib/scoot

# Media
MEDIA_DIR=/var/scoot/media
MEDIA_BASE_URL=http://localhost:3000/media

# Rocket.Chat client URL (used by Vite to embed the iframe)
VITE_RC_URL=http://localhost:3100

# Rocket.Chat
# RC runs on port 3100. Set RC_ROOT_URL to your public domain in production.
RC_ROOT_URL=http://localhost:3100
RC_ADMIN_USERNAME=rcadmin
RC_ADMIN_PASSWORD=changeme123
RC_ADMIN_EMAIL=admin@scoot.local
# Filled in after first RC boot (Admin > Integrations > Outgoing Webhook token):
RC_WEBHOOK_TOKEN=
# Filled in after creating the BigMo bot user in RC (Admin > Users > bot > API token):
RC_BOT_USER_ID=
RC_BOT_AUTH_TOKEN=

# Server
PORT=3000
NODE_ENV=development
