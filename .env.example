# Database
DATABASE_URL=postgresql://scoot:password@localhost:5432/scoot

# Session
SESSION_SECRET=replace_with_64_random_chars

# Default user — seeded automatically on first server start if the users table is empty.
# Required to log in on a fresh machine (public registration is disabled).
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=replace_me
DEFAULT_EMAIL=admin@example.com

# C core socket
SCOOTD_SOCKET=/tmp/scootd.sock

# LLM provider: "anthropic" | "openai_compat"
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514
# For vLLM or other OpenAI-compatible backend:
# LLM_PROVIDER=openai_compat
# LLM_API_URL=http://your-host:8000/v1
# LLM_MODEL=meta-llama/Llama-4-...

# Media
MEDIA_DIR=/var/scoot/media
MEDIA_BASE_URL=http://localhost:3000/media

# Server
PORT=3000
NODE_ENV=development
