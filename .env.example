# Database
DATABASE_URL=postgresql://scoot:password@localhost:5432/scoot

# Session
SESSION_SECRET=replace_with_64_random_chars

# Default user — seeded automatically on first server start if the users table is empty.
# Required to log in on a fresh machine (public registration is disabled).
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=replace_me
DEFAULT_EMAIL=admin@example.com

# C core socket
SCOOTD_SOCKET=/tmp/scootd.sock

# LLM provider: "anthropic" | "openai_compat"
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-5
# For vLLM or other OpenAI-compatible backend:
# LLM_PROVIDER=openai_compat
# LLM_API_URL=http://your-host:8000/v1
# LLM_MODEL=meta-llama/Llama-4-...

# Chat-bot mentions (the @<botname> in-room bot — separate from /bot page)
# Personality and per-bot config live in the `bots` table, not env.
BOT_ENABLED=true
BOT_HISTORY_WINDOW=20
BOT_MAX_REPLY_TOKENS=500
# Search backend for bots with search_enabled=true — set one, Perplexity takes priority.
# Gemini free tier (Google AI Studio): https://aistudio.google.com/apikey
# Perplexity (paid): https://www.perplexity.ai/settings/api
GEMINI_API_KEY=
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
LOG_LEVEL=debug

# Data volume root — all persistent data (postgres, media, scootchain) lives here.
# Point this at your data volume mount point in production (e.g. /mnt/data/scoot).
# Defaults to /var/lib/scoot if unset.
DATA_DIR=/var/lib/scoot

# Media
MEDIA_DIR=/var/scoot/media
MEDIA_BASE_URL=http://localhost:3000/media

# Server
PORT=3000
NODE_ENV=development

# Email (SendGrid)
SENDGRID_API_KEY=SG.replace_me

# SMS provider (currently only "twilio")
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Public URL Twilio is configured to POST inbound messages to.
# Required behind a reverse proxy so signature validation uses the URL Twilio actually signed.
# Example: https://thedreamlaboratory.org/api/v1/sms/inbound
SMS_INBOUND_URL=
# Set to "true" to echo inbound messages back as a TwiML reply (handy for bidirectional test)
SMS_AUTOREPLY=false
# Set to "true" ONLY during local dev with a tunnel that mangles the URL — skips signature check
TWILIO_SKIP_SIGNATURE=false
